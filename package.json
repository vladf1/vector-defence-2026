{
  "name": "vector-defence-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "build:pages": "svelte-check --tsconfig ./tsconfig.json && vite build --base=/vector-defence-2026/",
    "build:single": "svelte-check --tsconfig ./tsconfig.json && node scripts/build-single-html.mjs",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "playwright": "^1.59.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
